# =============================================================================
# Project Titan — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# =============================================================================

# ── IBKR Configuration ──────────────────────────────────────────────────────
IBKR_USERNAME=
IBKR_PASSWORD=
IBKR_TRADING_MODE=paper
IBKR_GATEWAY_HOST=ib-gateway
IBKR_GATEWAY_PORT=4002
IBKR_CLIENT_ID=1

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=titan
POSTGRES_USER=titan
POSTGRES_PASSWORD=

# ── QuestDB ──────────────────────────────────────────────────────────────────
QUESTDB_HOST=questdb
QUESTDB_HTTP_PORT=9000
QUESTDB_PG_PORT=8812

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── API Keys ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
POLYGON_API_KEY=
FINNHUB_API_KEY=
QUIVER_API_KEY=
FRED_API_KEY=
UNUSUAL_WHALES_API_KEY=

# ── Notifications ────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Twilio (optional — SMS alerts for critical events) ────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# ── Trading Parameters ──────────────────────────────────────────────────────
ACCOUNT_SIZE=150000
MAX_DRAWDOWN_PCT=0.15
PER_TRADE_RISK_PCT=0.02
MAX_CONCURRENT_POSITIONS=8
CONFIDENCE_THRESHOLD=0.78

# ── Claude AI ────────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_ANALYSIS_THINKING_BUDGET=16384
CLAUDE_RISK_THINKING_BUDGET=8192

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=
