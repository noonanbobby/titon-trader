# =============================================================================
# Project Titan — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# =============================================================================

# ── IBKR Configuration ──────────────────────────────────────────────────────
IBKR_USERNAME=your_username
IBKR_PASSWORD=your_password
IBKR_TRADING_MODE=paper
IBKR_GATEWAY_PORT=4002
IBKR_CLIENT_ID=1

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=titan
POSTGRES_USER=titan
POSTGRES_PASSWORD=change_me_to_a_secure_password

# ── QuestDB ──────────────────────────────────────────────────────────────────
QUESTDB_HOST=questdb
QUESTDB_HTTP_PORT=9000
QUESTDB_PG_PORT=8812

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── API Keys ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
POLYGON_API_KEY=your_polygon_key
UNUSUAL_WHALES_API_KEY=your_unusual_whales_key
FINNHUB_API_KEY=your_finnhub_key
QUIVER_API_KEY=your_quiver_key
FRED_API_KEY=your_fred_key

# ── Notifications ────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id
TWILIO_ACCOUNT_SID=your_sid
TWILIO_AUTH_TOKEN=your_token
TWILIO_FROM_NUMBER=+1234567890
TWILIO_TO_NUMBER=+1234567890

# ── Trading Parameters ──────────────────────────────────────────────────────
ACCOUNT_SIZE=150000
MAX_DRAWDOWN_PCT=0.15
PER_TRADE_RISK_PCT=0.02
MAX_CONCURRENT_POSITIONS=8
CONFIDENCE_THRESHOLD=0.78

# ── Claude AI ────────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-5-20250929
CLAUDE_ANALYSIS_THINKING_BUDGET=8192
CLAUDE_RISK_THINKING_BUDGET=4096

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
